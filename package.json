{
  "name": "study-space",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:server",
    "dev:web": "npm --workspace web run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace web run build && npm --workspace server run build",
    "test": "npm --workspace server run test",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "~5.6.0"
  }
}
